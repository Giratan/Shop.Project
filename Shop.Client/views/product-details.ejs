<h1><%= product.title %></h1>
<% if (product.thumbnail) { %>
    <img src="<%= product.thumbnail.url %>" alt="<%= product.title %>" />
<% } %>
<% if (product.images) { %>
    <% product.images.filter(img => !img.main).forEach(img => { %>
        <img src="<%= img.url %>" alt="<%= product.title %>" />
    <% }); %>
<% } %>
<p><%= product.description %></p>
<p>Цена: <%= product.price %></p>
<h2>Похожие товары</h2>
<% similar.forEach(sim => { %>
    <div>
        <a href="/<%= sim.id %>"><%= sim.title %></a>
        <p>Цена: <%= sim.price %></p>
    </div>
<% }); %>
<h2>Комментарии</h2>
<% if (product.comments) { %>
    <% product.comments.forEach(comment => { %>
        <div>
            <h3><%= comment.name %></h3>
            <p><%= comment.email %></p>
            <p><%= comment.body %></p>
        </div>
    <% }); %>
<% } %>
<h2>Добавить комментарий</h2>
<input type="text" id="commentName" placeholder="Заголовок" />
<input type="email" id="commentEmail" placeholder="E-mail" />
<textarea id="commentBody" placeholder="Текст комментария"></textarea>
<button onclick="addComment('<%= product.id %>')">Сохранить</button>