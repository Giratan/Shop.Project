{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es5",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@Shared/*": [
        "../Shared/*"
      ]
    },
    "ignoreDeprecations": "6.0"
  },
  "exclude": [
    "node_modules"
  ]
}