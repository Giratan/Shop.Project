{
  "compilerOptions": {
    "strict": true,
    "module": "commonjs",
    "target": "es5",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "./",
    "paths": {
      "@Shared/*": [
        "Shared/*"
      ]
    },
  },
  "exclude": [
    "node_modules"
  ]
}